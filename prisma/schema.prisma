generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ENUMS
enum store_type {
  WAREHOUSE
  BRANCH
  SHOP
}

enum movement_type {
  IN
  OUT
  TRANSFER
  ADJUST
}

// MASTER DATA
model users {
  id         String   @id @default(uuid()) @db.Uuid
  username   String   @unique @db.VarChar(100)
  password   String   @db.VarChar(255)
  firstname  String   @db.VarChar(255)
  lastname   String   @db.VarChar(255)
  is_active  Boolean
  created_by String   @db.VarChar(100)
  created_at DateTime @db.Timestamp(6)
  updated_by String   @db.VarChar(100)
  updated_at DateTime @db.Timestamp(6)
}

model stores {
  id         String   @id @default(uuid()) @db.Uuid
  code       String   @unique @db.VarChar(100)
  name_th    String   @db.VarChar(150)
  name_en    String   @db.VarChar(150)
  type       store_type
  address    String?  @db.Text
  is_active  Boolean
  created_by String   @db.VarChar(100)
  created_at DateTime @db.Timestamp(6)
  updated_by String   @db.VarChar(100)
  updated_at DateTime @db.Timestamp(6)
  stocks     stocks[]
  stock_movements stock_movements[]
}

model suppliers {
  id         String   @id @default(uuid()) @db.Uuid
  code       String   @unique @db.VarChar(50)
  name_th    String   @db.VarChar(150)
  name_en    String   @db.VarChar(150)
  phone      String   @db.VarChar(50)
  email      String   @db.VarChar(150)
  is_active  Boolean
  created_by String   @db.VarChar(100)
  created_at DateTime @db.Timestamp(6)
  updated_by String   @db.VarChar(100)
  updated_at DateTime @db.Timestamp(6)
  products   products[]
}

model categories {
  id         String   @id @default(uuid()) @db.Uuid
  code       String   @unique @db.VarChar(100)
  name_th    String   @db.VarChar(255)
  name_en    String   @db.VarChar(255)
  is_active  Boolean
  created_by String   @db.VarChar(100)
  created_at DateTime @db.Timestamp(6)
  updated_by String   @db.VarChar(100)
  updated_at DateTime @db.Timestamp(6)
  sub_categories sub_categories[]
  products   products[]
}

model sub_categories {
  id         String   @id @default(uuid()) @db.Uuid
  code       String   @unique @db.VarChar(100)
  category_id String  @db.Uuid
  name_th    String   @db.VarChar(150)
  name_en    String   @db.VarChar(150)
  is_active  Boolean
  created_by String   @db.VarChar(100)
  created_at DateTime @db.Timestamp(6)
  updated_by String   @db.VarChar(100)
  updated_at DateTime @db.Timestamp(6)
  category   categories @relation(fields: [category_id], references: [id])
  products   products[]
}

model units {
  id         String   @id @default(uuid()) @db.Uuid
  code       String   @unique @db.VarChar(100)
  name_th    String   @db.VarChar(255)
  name_en    String   @db.VarChar(255)
  is_active  Boolean
  created_by String   @db.VarChar(100)
  created_at DateTime @db.Timestamp(6)
  updated_by String   @db.VarChar(100)
  updated_at DateTime @db.Timestamp(6)
  products   products[]
}

model products {
  id             String   @id @default(uuid()) @db.Uuid
  code           String   @unique @db.VarChar(100)
  name_th        String   @db.VarChar(255)
  name_en        String   @db.VarChar(255)
  category_id    String   @db.Uuid
  sub_category_id String  @db.Uuid
  unit_id        String   @db.Uuid
  supplier_id    String   @db.Uuid
  cost_price     Decimal  @db.Decimal
  sale_price     Decimal  @db.Decimal
  is_active      Boolean
  created_by     String   @db.VarChar(100)
  created_at     DateTime @db.Timestamp(6)
  updated_by     String   @db.VarChar(100)
  updated_at     DateTime @db.Timestamp(6)
  category       categories @relation(fields: [category_id], references: [id])
  sub_category   sub_categories @relation(fields: [sub_category_id], references: [id])
  unit           units @relation(fields: [unit_id], references: [id])
  supplier       suppliers @relation(fields: [supplier_id], references: [id])
  stocks         stocks[]
  stock_movements stock_movements[]
}

// TRANSACTION
model stocks {
  id         String   @id @default(uuid()) @db.Uuid
  product_id String   @db.Uuid
  store_id   String   @db.Uuid
  quantity   Decimal  @db.Decimal
  created_by String   @db.VarChar(100)
  created_at DateTime @db.Timestamp(6)
  updated_by String   @db.VarChar(100)
  updated_at DateTime @db.Timestamp(6)
  product    products @relation(fields: [product_id], references: [id])
  store      stores   @relation(fields: [store_id], references: [id])
}

model stock_movements {
  id            String        @id @default(uuid()) @db.Uuid
  product_id    String        @db.Uuid
  store_id      String        @db.Uuid
  movement_type movement_type
  quantity      Decimal       @db.Decimal
  remark        String?       @db.Text
  created_by    String        @db.VarChar(100)
  created_at    DateTime      @db.Timestamp(6)
  updated_by    String        @db.VarChar(100)
  updated_at    DateTime      @db.Timestamp(6)
  product       products      @relation(fields: [product_id], references: [id])
  store         stores        @relation(fields: [store_id], references: [id])
}
